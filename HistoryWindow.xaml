<Window x:Class="BoltFetch.HistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource Loc_HistoryTitle}" Height="500" Width="800"
        WindowStartupLocation="CenterOwner" Background="#0F172A">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="{DynamicResource Loc_HistoryTitle}" FontSize="24" FontWeight="Bold" Foreground="White" Margin="0,0,0,20"/>

        <DataGrid x:Name="HistoryDataGrid" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" 
                  Background="#1E293B" Foreground="White" BorderThickness="0" 
                  RowBackground="#1E293B" AlternatingRowBackground="#162031">
            <DataGrid.Columns>
                <DataGridTextColumn Header="{DynamicResource Loc_HistColDate}" Binding="{Binding Timestamp, StringFormat=\{0:dd/MM/yyyy HH:mm\}}" Width="140" FontSize="13"/>
                <DataGridTextColumn Header="{DynamicResource Loc_HistColName}" Binding="{Binding FileName}" Width="*" FontSize="13"/>
                <DataGridTextColumn Header="{DynamicResource Loc_HistColSize}" Binding="{Binding SizeDisplay}" Width="100" FontSize="13"/>
                <DataGridTextColumn Header="{DynamicResource Loc_HistColCat}" Binding="{Binding Category}" Width="100" FontSize="13"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <TextBlock Text="{DynamicResource Loc_HistTotalDisp}" Foreground="#94A3B8" FontSize="14" VerticalAlignment="Center" Margin="0,0,10,0"/>
            <TextBlock x:Name="TotalDownloadedText" Text="0 GB" Foreground="#4ADE80" FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
        </StackPanel>
    </Grid>
</Window>
