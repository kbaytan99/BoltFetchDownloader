<Window x:Class="BoltFetch.NotificationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Notification" Height="110" Width="380"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ShowInTaskbar="False" Topmost="True" WindowStartupLocation="Manual">
    <Border Background="#0F172A" CornerRadius="14" BorderBrush="#3ABEF9" BorderThickness="1.5" Padding="0">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="2" Color="#3ABEF9" Opacity="0.35"/>
        </Border.Effect>
        <Grid>
            <!-- Accent bar on left -->
            <Border Background="#3ABEF9" CornerRadius="14,0,0,14" Width="5" HorizontalAlignment="Left"/>
            
            <Grid Margin="20,12,15,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Icon -->
                <Border Grid.Column="0" Background="#1E293B" CornerRadius="10" Width="44" Height="44" Margin="0,0,14,0">
                    <TextBlock Text="⚡" FontSize="22" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                </Border>

                <!-- Text -->
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock x:Name="TitleText" Text="New Files Added!" FontSize="14" FontWeight="Bold" Foreground="#3ABEF9"/>
                    <TextBlock x:Name="MessageText" Text="" FontSize="12" Foreground="#94A3B8" Margin="0,3,0,0" TextWrapping="Wrap" MaxWidth="240" TextTrimming="CharacterEllipsis" MaxHeight="32"/>
                </StackPanel>

                <!-- Close -->
                <Button Grid.Column="2" Content="✕" VerticalAlignment="Top" Margin="0,-2,0,0"
                        Background="Transparent" Foreground="#475569" BorderThickness="0" FontSize="13"
                        Cursor="Hand" Click="CloseBtn_Click" Width="22" Height="22">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bg" Background="Transparent" CornerRadius="6">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bg" Property="Background" Value="#1E293B"/>
                                    <Setter Property="Foreground" Value="#E2E8F0"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Grid>
    </Border>
</Window>
