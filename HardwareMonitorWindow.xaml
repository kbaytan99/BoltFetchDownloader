<Window x:Class="BoltFetch.HardwareMonitorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource Loc_MonTitle}" Height="700" Width="400"
        Icon="Resources/logo.png"
        Background="#0F172A" Foreground="#E2E8F0" WindowStartupLocation="CenterOwner"
        WindowStyle="None" AllowsTransparency="True" ResizeMode="NoResize"
        Deactivated="Window_Deactivated" MouseDown="Window_MouseDown">
    <Border BorderBrush="#334155" BorderThickness="1" Background="#0F172A" CornerRadius="12">
        <Grid Margin="30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Margin="0,0,0,20">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="{DynamicResource Loc_MonTitle}" FontSize="20" FontWeight="Bold" Foreground="#3ABEF9" HorizontalAlignment="Center"/>
                    <TextBlock Text="{DynamicResource Loc_MonSubtitle}" FontSize="12" Foreground="#94A3B8" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                </StackPanel>
                <Button Content="✕" Width="30" Height="30" Click="Close_Click" Background="Transparent" Foreground="#94A3B8" BorderThickness="0" FontSize="16" Cursor="Hand" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-20,-20,0">
                    <Button.Template><ControlTemplate TargetType="Button"><Border x:Name="bg" Background="Transparent"><TextBlock Text="✕" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border><ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="bg" Property="Background" Value="#E81123"/><Setter Property="Foreground" Value="White"/></Trigger></ControlTemplate.Triggers></ControlTemplate></Button.Template>
                </Button>
            </Grid>

            <!-- Metrics Content -->
            <StackPanel Grid.Row="1" Orientation="Vertical">
                
                <!-- CPU -->
                <Grid Margin="0,5,0,5">
                    <TextBlock x:Name="CpuLabel" Text="CPU" FontSize="11" FontWeight="Bold" Foreground="#3ABEF9"/>
                    <TextBlock x:Name="CpuText" Text="0.0 %" FontSize="12" FontWeight="Bold" Foreground="White" HorizontalAlignment="Right"/>
                </Grid>
                <Border Height="50" BorderBrush="#334155" BorderThickness="1" CornerRadius="4" Background="#0F172A" Margin="0,0,0,10">
                    <Grid>
                        <!-- Grid lines -->
                        <Line X1="0" Y1="25" X2="400" Y2="25" Stroke="#1E293B" StrokeThickness="1" StrokeDashArray="2,2"/>
                        <Canvas x:Name="CpuCanvas" ClipToBounds="True">
                            <Polyline x:Name="CpuLine" Stroke="#4ADE80" StrokeThickness="1.5" />
                        </Canvas>
                    </Grid>
                </Border>

                <!-- RAM -->
                <Grid Margin="0,5,0,5">
                    <TextBlock x:Name="RamLabel" Text="RAM" FontSize="11" FontWeight="Bold" Foreground="#3ABEF9"/>
                    <TextBlock x:Name="RamPercentText" Text="0.0 %" FontSize="12" FontWeight="Bold" Foreground="White" HorizontalAlignment="Right"/>
                </Grid>
                <Border Height="50" BorderBrush="#334155" BorderThickness="1" CornerRadius="4" Background="#0F172A" Margin="0,0,0,2">
                    <Grid>
                        <!-- Grid lines -->
                        <Line X1="0" Y1="25" X2="400" Y2="25" Stroke="#1E293B" StrokeThickness="1" StrokeDashArray="2,2"/>
                        <Canvas x:Name="RamCanvas" ClipToBounds="True">
                            <Polyline x:Name="RamLine" Stroke="#A78BFA" StrokeThickness="1.5" />
                        </Canvas>
                    </Grid>
                </Border>
                <TextBlock x:Name="RamDetailsText" Text="0 MB / 0 MB" FontSize="11" Foreground="#94A3B8" HorizontalAlignment="Right" Margin="0,0,0,10"/>

                <!-- GPU -->
                <Grid Margin="0,5,0,5">
                    <TextBlock x:Name="GpuLabel" Text="GPU (3D)" FontSize="11" FontWeight="Bold" Foreground="#3ABEF9"/>
                    <TextBlock x:Name="GpuText" Text="0.0 %" FontSize="12" FontWeight="Bold" Foreground="White" HorizontalAlignment="Right"/>
                </Grid>
                <Border Height="50" BorderBrush="#334155" BorderThickness="1" CornerRadius="4" Background="#0F172A" Margin="0,0,0,10">
                    <Grid>
                        <!-- Grid lines -->
                        <Line X1="0" Y1="25" X2="400" Y2="25" Stroke="#1E293B" StrokeThickness="1" StrokeDashArray="2,2"/>
                        <Canvas x:Name="GpuCanvas" ClipToBounds="True">
                            <Polyline x:Name="GpuLine" Stroke="#F59E0B" StrokeThickness="1.5" />
                        </Canvas>
                    </Grid>
                </Border>

                <!-- Disk Usage -->
                <Grid Margin="0,5,0,5">
                    <TextBlock Text="{DynamicResource Loc_MonDisk}" FontSize="11" FontWeight="Bold" Foreground="#3ABEF9"/>
                    <TextBlock x:Name="DiskTimeText" Text="0.0 %" FontSize="12" FontWeight="Bold" Foreground="White" HorizontalAlignment="Right"/>
                </Grid>
                <Border Height="50" BorderBrush="#334155" BorderThickness="1" CornerRadius="4" Background="#0F172A" Margin="0,0,0,5">
                    <Grid>
                        <!-- Grid lines -->
                        <Line X1="0" Y1="25" X2="400" Y2="25" Stroke="#1E293B" StrokeThickness="1" StrokeDashArray="2,2"/>
                        <Canvas x:Name="DiskCanvas" ClipToBounds="True">
                            <Polyline x:Name="DiskLine" Stroke="#F43F5E" StrokeThickness="1.5" />
                        </Canvas>
                    </Grid>
                </Border>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,10">
                    <TextBlock Text="{DynamicResource Loc_MonRead}" FontSize="11" Foreground="#94A3B8"/>
                    <TextBlock x:Name="DiskReadText" Text="0 KB/s" FontSize="11" Foreground="#F8FAFC" Margin="0,0,15,0" FontWeight="SemiBold"/>
                    <TextBlock Text="{DynamicResource Loc_MonWrite}" FontSize="11" Foreground="#94A3B8"/>
                    <TextBlock x:Name="DiskWriteText" Text="0 KB/s" FontSize="11" Foreground="#F8FAFC" FontWeight="SemiBold"/>
                </StackPanel>
                
                <!-- Network Usage -->
                <TextBlock x:Name="NetLabel" Text="NETWORK" FontSize="11" FontWeight="Bold" Foreground="#3ABEF9" Margin="0,5,0,5"/>
                <Border Height="50" BorderBrush="#334155" BorderThickness="1" CornerRadius="4" Background="#0F172A" Margin="0,0,0,5">
                    <Grid>
                        <!-- Grid lines -->
                        <Line X1="0" Y1="25" X2="400" Y2="25" Stroke="#1E293B" StrokeThickness="1" StrokeDashArray="2,2"/>
                        <Canvas x:Name="NetCanvas" ClipToBounds="True">
                            <Polyline x:Name="NetReadLine" Stroke="#4ADE80" StrokeThickness="1.5" />
                            <Polyline x:Name="NetWriteLine" Stroke="#F59E0B" StrokeThickness="1.5" />
                        </Canvas>
                    </Grid>
                </Border>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,10">
                    <TextBlock Text="{DynamicResource Loc_MonDownload}" FontSize="11" Foreground="#94A3B8"/>
                    <TextBlock x:Name="NetReadText" Text="0 KB/s" FontSize="11" Foreground="#4ADE80" Margin="0,0,15,0" FontWeight="SemiBold"/>
                    <TextBlock Text="{DynamicResource Loc_MonUpload}" FontSize="11" Foreground="#94A3B8"/>
                    <TextBlock x:Name="NetWriteText" Text="0 KB/s" FontSize="11" Foreground="#F59E0B" FontWeight="SemiBold"/>
                </StackPanel>

            </StackPanel>

            <!-- Actions Removed -->
        </Grid>
    </Border>
</Window>
