<Window x:Class="BoltFetch.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings" Height="800" Width="550"
        Icon="Resources/logo.png"
        Background="#0F172A" Foreground="#E2E8F0" WindowStartupLocation="CenterOwner"
        WindowStyle="None" AllowsTransparency="True" ResizeMode="NoResize">
    <Border BorderBrush="#334155" BorderThickness="1" Background="#0F172A" CornerRadius="12">
        <Grid Margin="30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Margin="0,0,0,30" HorizontalAlignment="Center">
                <Image Source="Resources/logo.png" Height="80" Margin="0,0,0,10" RenderOptions.BitmapScalingMode="HighQuality"/>
                <TextBlock Text="SETTINGS" FontSize="24" FontWeight="Bold" Foreground="#3ABEF9" HorizontalAlignment="Center"/>
            </StackPanel>

            <!-- Form Content -->
            <StackPanel Grid.Row="1">
                <!-- Download Path -->
                <TextBlock Text="DOWNLOAD DIRECTORY" FontSize="11" FontWeight="Bold" Foreground="#3ABEF9" Margin="0,0,0,8"/>
                <Grid Margin="0,0,0,25">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="PathTextBox" Height="40" VerticalContentAlignment="Center" Background="#1E293B" Foreground="White" BorderBrush="#334155" BorderThickness="1" Padding="10,0" FontSize="13"/>
                    <Button Content="BROWSE" Grid.Column="1" Width="100" Margin="10,0,0,0" Click="Browse_Click" Background="#2D3748" Foreground="White" BorderThickness="0" FontWeight="SemiBold" FontSize="11"/>
                </Grid>

                <!-- Language Selection -->
                <TextBlock Text="LANGUAGE / DİL" FontSize="11" FontWeight="Bold" Foreground="#3ABEF9" Margin="0,0,0,8"/>
                <ComboBox x:Name="LanguageComboBox" Height="40" VerticalContentAlignment="Center" Padding="10,0" Margin="0,0,0,25" FontSize="13">
                    <ComboBoxItem Tag="en" IsSelected="True" Foreground="Black">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🇬🇧" FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="English" VerticalAlignment="Center"/>
                        </StackPanel>
                    </ComboBoxItem>
                </ComboBox>

                <!-- Max Parallel -->
                <TextBlock Text="MAX PARALLEL DOWNLOADS" FontSize="11" FontWeight="Bold" Foreground="#3ABEF9" Margin="0,0,0,8"/>
                <TextBox x:Name="ParallelTextBox" Height="40" VerticalContentAlignment="Center" Background="#1E293B" Foreground="White" BorderBrush="#334155" Padding="10,0" Margin="0,0,0,25" FontSize="14"/>

                <!-- Speed Limit -->
                <TextBlock Text="SPEED LIMIT (KB/s) - 0 for unlimited" FontSize="11" FontWeight="Bold" Foreground="#3ABEF9" Margin="0,0,0,8"/>
                <TextBox x:Name="SpeedLimitTextBox" Height="40" VerticalContentAlignment="Center" Background="#1E293B" Foreground="White" BorderBrush="#334155" Padding="10,0" Margin="0,0,0,25" FontSize="14"/>

                <!-- Segments -->
                <TextBlock Text="SEGMENTS PER FILE (Multi-Thread Chunks)" FontSize="11" FontWeight="Bold" Foreground="#3ABEF9" Margin="0,0,0,8"/>
                <TextBox x:Name="SegmentsTextBox" Height="40" VerticalContentAlignment="Center" Background="#1E293B" Foreground="White" BorderBrush="#334155" Padding="10,0" FontSize="14"/>

                <!-- Active Providers Overview -->
                <TextBlock Text="ACTIVE PROVIDERS" FontSize="11" FontWeight="Bold" Foreground="#3ABEF9" Margin="0,20,0,8"/>
                <Border Background="#0C1322" BorderBrush="#334155" BorderThickness="1" Padding="12" CornerRadius="6">
                    <StackPanel>
                        <TextBlock Text="✓ GoFile.io (Smart Token API)" Foreground="#16A34A" FontSize="12" FontWeight="SemiBold"/>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Actions -->
            <StackPanel Grid.Row="2" Orientation="Vertical" Margin="0,20,0,0">
                <TextBlock Text="{DynamicResource Loc_AppVersion}" Foreground="#64748B" FontSize="10" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="CANCEL" Width="120" Height="45" Margin="0,0,15,0" Click="Cancel_Click" Background="Transparent" Foreground="#94A3B8" BorderThickness="1" BorderBrush="#334155" FontSize="12" FontWeight="Bold"/>
                    <Button Content="SAVE CHANGES" Width="160" Height="45" Click="Save_Click" Background="#3ABEF9" Foreground="#0F172A" BorderThickness="0" FontWeight="Bold" FontSize="12">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="6"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>
            </StackPanel>
        </Grid>
    </Border>
</Window>
