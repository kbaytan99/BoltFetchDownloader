<Window x:Class="BoltFetch.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:BoltFetch.Views"
        xmlns:converters="clr-namespace:BoltFetch.Converters"
        mc:Ignorable="d"
        Title="BoltFetch Downloader" Height="950" Width="1400"
        MinWidth="1100" MinHeight="700"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Window.Resources>
        <converters:ProgressToAngleConverter x:Key="ProgressToAngleConverter"/>
        <converters:StatusToColorConverter x:Key="StatusToColorConverter"/>
        <converters:InverseBooleanToVisibilityConverter x:Key="InverseVisibilityConverter"/>
        
        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Background" Value="#1E293B"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" 
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#334155"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="#0F172A" CornerRadius="15" BorderBrush="#1E293B" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- Title Bar -->
                <RowDefinition Height="*"/>    <!-- Content -->
                <RowDefinition Height="Auto"/> <!-- Footer -->
            </Grid.RowDefinitions>

            <!-- Title Bar -->
            <Grid Grid.Row="0" Background="#1E293B" Height="40" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="15,0">
                    <Image Source="/Resources/logo.png" Height="20" Margin="0,0,10,0"/>
                    <TextBlock Text="BoltFetch Downloader" Foreground="#94A3B8" FontWeight="SemiBold"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="−" Style="{StaticResource ModernButton}" Click="MinimizeBtn_Click" Width="40" Background="Transparent"/>
                    <Button Content="✕" Style="{StaticResource ModernButton}" Click="CloseBtn_Click" Width="40" Background="Transparent"/>
                </StackPanel>
            </Grid>

            <!-- Placeholder Content to get it building -->
            <Grid Grid.Row="1">
                <TextBlock Text="Restoring UI..." Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="24"/>
            </Grid>
            
            <StatusBar Grid.Row="2" Background="#1E293B" Foreground="#94A3B8" Padding="10,5">
                <StatusBarItem>
                    <TextBlock x:Name="StatusText" Text="Ready"/>
                </StatusBarItem>
            </StatusBar>
        </Grid>
    </Border>
</Window>