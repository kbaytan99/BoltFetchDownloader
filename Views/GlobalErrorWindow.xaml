<Window x:Class="BoltFetch.GlobalErrorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Error" Height="300" Width="450"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        MouseDown="Window_MouseDown"
        Deactivated="Window_Deactivated">

    <Window.Resources>
        <ControlTemplate x:Key="ModernButton" TargetType="Button">
            <Border Background="{TemplateBinding Background}"
                    CornerRadius="8"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}">
                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.8"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Opacity" Value="0.6"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>
    </Window.Resources>

    <Border Background="#1E293B" CornerRadius="12" BorderThickness="1" BorderBrush="#334155" Margin="10">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="15" Opacity="0.5" Direction="270" ShadowDepth="5"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title Bar -->
            <Border Grid.Row="0" Background="#0F172A" CornerRadius="12,12,0,0" Padding="15,10">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock Text="⚠" Foreground="#EF4444" FontSize="16" Margin="0,0,10,0"/>
                    <TextBlock Text="An Unexpected Error Occurred" Foreground="White" FontSize="14" FontWeight="SemiBold"/>
                </StackPanel>
            </Border>

            <!-- Error Content -->
            <ScrollViewer Grid.Row="1" Margin="20,20,20,10" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock x:Name="ErrorMessageText" 
                               TextWrapping="Wrap" 
                               Foreground="#CBD5E1" 
                               FontSize="13" 
                               LineHeight="20"
                               Margin="0,0,0,10"/>
                    
                    <!-- Context Section -->
                    <Border Background="#0F172A" CornerRadius="8" Padding="10" Visibility="Collapsed" x:Name="ContextBorder">
                        <TextBlock x:Name="ContextMessageText" 
                                   TextWrapping="Wrap" 
                                   Foreground="#94A3B8" 
                                   FontSize="12" 
                                   FontFamily="Consolas, Courier New"
                                   LineHeight="18"/>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- Buttons -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,20,20">
                <TextBlock x:Name="ClipboardHint" 
                           Text="Screenshot copied!" 
                           Foreground="#10B981" 
                           VerticalAlignment="Center" 
                           Margin="0,0,15,0"
                           Visibility="Hidden"
                           FontSize="12" FontWeight="SemiBold"/>
                
                <Button Content="Report Bug on GitHub" 
                        Width="160" Height="36" 
                        Background="#2563EB" 
                        Foreground="White" 
                        FontWeight="Medium" 
                        BorderThickness="0"
                        Margin="0,0,10,0"
                        Template="{StaticResource ModernButton}"
                        Click="ReportBug_Click" Cursor="Hand"/>

                <Button Content="Close" 
                        Width="100" Height="36" 
                        Background="#334155" 
                        Foreground="White" 
                        FontWeight="Medium" 
                        BorderThickness="1" BorderBrush="#475569"
                        Template="{StaticResource ModernButton}"
                        Click="Close_Click" Cursor="Hand"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
