<Window x:Class="BoltFetch.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:BoltFetch"
        mc:Ignorable="d"
        Title="BoltFetch Downloader" Height="750" Width="1100"
        MinHeight="650" MinWidth="1000"
        Icon="Resources/logo.png"
        Background="#0F172A" Foreground="#E2E8F0"
        WindowStyle="SingleBorderWindow">
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="35" ResizeBorderThickness="5" GlassFrameThickness="0" CornerRadius="0" UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>
    <Window.Resources>
        <!-- Premium Thin ScrollBar -->
        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Width" Value="8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Border Background="Transparent">
                            <Track x:Name="PART_Track" IsDirectionReversed="true">
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="#334155" CornerRadius="4" Margin="2,0"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Modern Button Style with Animation -->
        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Background" Value="#1E293B"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#334155"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" BorderThickness="{TemplateBinding BorderThickness}" BorderBrush="{TemplateBinding BorderBrush}" CornerRadius="19">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter Property="Background" TargetName="border" Value="#334155"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="true">
                                <Setter Property="Background" TargetName="border" Value="#0F172A"/>
                                <Setter Property="RenderTransform" TargetName="border">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.97" ScaleY="0.97" CenterX="0.5" CenterY="0.5"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="35"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Custom Title Bar -->
        <Grid Grid.Row="0" Background="#0C1322" WindowChrome.IsHitTestVisibleInChrome="False">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="15,0,0,0">
                <Image Source="Resources/logo.png" Height="18" Margin="0,0,8,0" RenderOptions.BitmapScalingMode="HighQuality"/>
                <TextBlock Text="BoltFetch Downloader" FontSize="13" FontWeight="SemiBold" Foreground="#94A3B8" VerticalAlignment="Center"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" WindowChrome.IsHitTestVisibleInChrome="True">
                <Button Content="—" Width="46" Background="Transparent" Foreground="#94A3B8" BorderThickness="0" Click="MinimizeBtn_Click" Cursor="Hand">
                    <Button.Template><ControlTemplate TargetType="Button"><Border x:Name="bg" Background="Transparent"><TextBlock Text="—" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,5"/></Border><ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="bg" Property="Background" Value="#1E293B"/></Trigger></ControlTemplate.Triggers></ControlTemplate></Button.Template>
                </Button>
                <Button Content="☐" Width="46" Background="Transparent" Foreground="#94A3B8" BorderThickness="0" Click="MaximizeBtn_Click" Cursor="Hand">
                    <Button.Template><ControlTemplate TargetType="Button"><Border x:Name="bg" Background="Transparent"><TextBlock Text="☐" FontSize="15" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,-3,0,0"/></Border><ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="bg" Property="Background" Value="#1E293B"/></Trigger></ControlTemplate.Triggers></ControlTemplate></Button.Template>
                </Button>
                <Button Content="✕" Width="46" Background="Transparent" Foreground="#94A3B8" BorderThickness="0" Click="CloseBtn_Click" Cursor="Hand">
                    <Button.Template><ControlTemplate TargetType="Button"><Border x:Name="bg" Background="Transparent"><TextBlock Text="✕" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border><ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="bg" Property="Background" Value="#E81123"/><Setter Property="Foreground" Value="White"/></Trigger></ControlTemplate.Triggers></ControlTemplate></Button.Template>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Content Frame -->
        <Grid Grid.Row="1" Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
        <DockPanel Grid.Row="0" Margin="0,0,0,20">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Image Source="Resources/logo.png" Height="60" Margin="0,0,15,0" RenderOptions.BitmapScalingMode="HighQuality"/>
                <TextBlock Text="BoltFetch Downloader" FontSize="32" FontWeight="Bold" Foreground="#3ABEF9" VerticalAlignment="Center">
                    <TextBlock.Effect>
                        <DropShadowEffect BlurRadius="15" ShadowDepth="0" Color="#3ABEF9" Opacity="0.4"/>
                    </TextBlock.Effect>
                </TextBlock>
            </StackPanel>
            
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <Button x:Name="AddButton" Style="{StaticResource ModernButton}" Content="+" Width="40" Height="40" Margin="0,0,10,0"
                        Click="AddButton_Click" Background="#1E293B" Foreground="#3ABEF9" FontWeight="Bold" FontSize="20" ToolTip="Add links manually">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="20"/>
                        </Style>
                    </Button.Resources>
                </Button>
                
                <Button x:Name="SettingsButton" Style="{StaticResource ModernButton}" 
                        Width="110" Height="38" Click="SettingsButton_Click"
                        Background="#1E293B" BorderBrush="#334155" BorderThickness="1">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Settings" VerticalAlignment="Center" Margin="0,0,8,0" FontWeight="SemiBold" Foreground="#CBD5E1"/>
                        <TextBlock Text="⚙" FontSize="16" VerticalAlignment="Center" Foreground="#3ABEF9"/>
                    </StackPanel>
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="19"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </StackPanel>
        </DockPanel>

        <!-- No Link Entry Here Anymore. Removed LinkTextBox block. -->


        <!-- File List -->
        <!-- File List -->
        <DataGrid x:Name="FilesDataGrid" Grid.Row="2" AutoGenerateColumns="False" CanUserAddRows="False"
                  Background="Transparent" RowBackground="Transparent" BorderThickness="0"
                  HeadersVisibility="Column" SelectionMode="Extended" RowHeight="50" GridLinesVisibility="None">
            <DataGrid.Resources>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="#1E293B"/>
                    <Setter Property="Foreground" Value="#CBD5E1"/>
                    <Setter Property="Padding" Value="10,8"/>
                    <Setter Property="FontSize" Value="13"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                    <Setter Property="BorderThickness" Value="0,0,0,2"/>
                    <Setter Property="BorderBrush" Value="#3ABEF9"/>
                </Style>
                <Style TargetType="DataGridRow">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="BorderBrush" Value="#1E293B"/>
                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#1E293B"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="#1E3ABEF9"/>
                            <Setter Property="BorderBrush" Value="#3ABEF9"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.Resources>
            <DataGrid.Columns>
                <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*" IsReadOnly="True" FontSize="14">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                            <Setter Property="ToolTip" Value="{Binding Name}"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Size" Binding="{Binding SizeFormatted}" Width="Auto" MinWidth="100" IsReadOnly="True" FontSize="13"/>
                <DataGridTemplateColumn Header="Progress" Width="1.5*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Grid Margin="10,0">
                                <ProgressBar Value="{Binding ProgressValue}" Maximum="100" Height="20" BorderThickness="0">
                                    <ProgressBar.Template>
                                        <ControlTemplate TargetType="ProgressBar">
                                            <Border Background="#1E293B" CornerRadius="10" ClipToBounds="True">
                                                <Border x:Name="PART_Indicator" Background="#3ABEF9" CornerRadius="10" HorizontalAlignment="Left" />
                                            </Border>
                                        </ControlTemplate>
                                    </ProgressBar.Template>
                                </ProgressBar>
                                <TextBlock Text="{Binding ProgressText}" HorizontalAlignment="Center" 
                                           VerticalAlignment="Center" FontSize="12" FontWeight="Bold" Foreground="White">
                                    <TextBlock.Effect>
                                        <DropShadowEffect BlurRadius="2" ShadowDepth="1" Color="Black"/>
                                    </TextBlock.Effect>
                                </TextBlock>
                            </Grid>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="Speed" Binding="{Binding SpeedText}" Width="Auto" MinWidth="110" IsReadOnly="True" FontSize="13"/>
                <DataGridTextColumn Header="ETA" Binding="{Binding ETAText}" Width="Auto" MinWidth="90" IsReadOnly="True" FontSize="13"/>
                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="Auto" MinWidth="140" IsReadOnly="True" FontSize="13" Foreground="#AAA"/>
                <DataGridTemplateColumn Header="Controls" Width="340">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <!-- Active Download Controls -->
                                <StackPanel Orientation="Horizontal" Visibility="{Binding IsNotCompleted, Converter={StaticResource BoolToVis}}">
                                    <Button x:Name="StartItemButton" Content="Start ▶" Width="55" Height="30" Margin="2" 
                                            Background="#28A745" Foreground="White" BorderThickness="0" FontSize="11"
                                            Click="RetryItemButton_Click" ToolTip="Start/Resume"/>
                                    <Button x:Name="StopItemButton" Content="Stop ⏹" Width="55" Height="30" Margin="2" 
                                            Background="#DC3545" Foreground="White" BorderThickness="0" FontSize="11"
                                            Click="StopItemButton_Click" ToolTip="Stop Download"/>
                                </StackPanel>
                                
                                <!-- File Management Controls (Completed Only) -->
                                <StackPanel Orientation="Horizontal" Visibility="{Binding IsCompleted, Converter={StaticResource BoolToVis}}">
                                    <Button x:Name="LocateItemButton" Content="Open 📂" Width="80" Height="30" Margin="2" 
                                            Background="#3ABEF9" Foreground="#0F172A" BorderThickness="0" FontSize="11" FontWeight="Bold"
                                            Click="LocateItemButton_Click" ToolTip="Locate File in Folder"/>
                                </StackPanel>
                                
                                <!-- Universal Actions -->
                                <Button x:Name="RemoveItemButton" Content="Remove ✖" Width="70" Height="30" Margin="2" 
                                        Background="#334155" Foreground="#CBD5E1" BorderThickness="0" FontSize="11"
                                        Click="RemoveItem_Click" ToolTip="Remove from list only (keeps file on disk)"/>
                                <Button x:Name="DeleteItemButton" Content="Delete 🗑️" Width="70" Height="30" Margin="2" 
                                        Background="#DC3545" Foreground="White" BorderThickness="0" FontSize="11"
                                        Click="DeleteItemButton_Click" ToolTip="Permanently delete from list and disk"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Summary Footer -->
        <Border Grid.Row="3" Background="#1E293B" Margin="0,20,0,0" Padding="0" CornerRadius="8" BorderBrush="#334155" BorderThickness="1" ClipToBounds="True">
            <Grid>
                <!-- Speed Graph Background -->
                <Canvas x:Name="SpeedGraphCanvas" VerticalAlignment="Bottom" Height="80" ClipToBounds="True">
                    <Polygon x:Name="SpeedGraphFill" Fill="#1E3ABEF9" />
                    <Polyline x:Name="SpeedGraphLine" Stroke="#3ABEF9" StrokeThickness="2" />
                </Canvas>
                
                <Grid Margin="20,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Vertical" Grid.Column="0">
                    <TextBlock Text="TOTAL SIZE" Foreground="#3ABEF9" FontSize="12" FontWeight="Bold"/>
                    <TextBlock x:Name="TotalSizeText" Text="0.00 GB" FontSize="22" FontWeight="SemiBold" Margin="0,5,0,0" Foreground="#F8FAFC"/>
                </StackPanel>
                
                <StackPanel Orientation="Vertical" Grid.Column="1" HorizontalAlignment="Center">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="30"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="30"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                            <TextBlock Text="QUEUED" Foreground="#94A3B8" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="QueuedCountText" Text="0" FontSize="20" FontWeight="SemiBold" HorizontalAlignment="Center" Foreground="#F8FAFC"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                            <TextBlock Text="ACTIVE" Foreground="#4ADE80" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="ActiveCountText" Text="0" FontSize="20" FontWeight="SemiBold" HorizontalAlignment="Center" Foreground="#F8FAFC"/>
                        </StackPanel>
                        <StackPanel Grid.Column="4" HorizontalAlignment="Center">
                            <TextBlock Text="FINISHED" Foreground="#3ABEF9" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="FinishedCountText" Text="0" FontSize="20" FontWeight="SemiBold" HorizontalAlignment="Center" Foreground="#F8FAFC"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
                <StackPanel Orientation="Vertical" Grid.Column="2" HorizontalAlignment="Right">
                    <TextBlock Text="TOTAL SPEED" Foreground="#3ABEF9" FontSize="12" FontWeight="Bold" HorizontalAlignment="Right"/>
                    <TextBlock x:Name="TotalSpeedText" Text="0 KB/s" FontSize="22" FontWeight="SemiBold" Margin="0,5,0,0" HorizontalAlignment="Right" Foreground="#F8FAFC"/>
                </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <!-- Main Actions -->
        <Grid Grid.Row="4" Margin="0,20,0,0">
            <StackPanel Orientation="Vertical" VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Active Parallel Slots: " Foreground="#64748B" FontSize="13"/>
                    <TextBlock x:Name="ParallelLimitText" Text="3" Foreground="#3ABEF9" FontSize="13" FontWeight="Bold"/>
                    <TextBlock Text=" | Version: " Foreground="#64748B" FontSize="13" Margin="10,0,0,0"/>
                    <TextBlock Text="1.4.0" Foreground="#FFD700" FontSize="13" FontWeight="Bold"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                    <TextBlock Text="Download Folder: " Foreground="#64748B" FontSize="12"/>
                    <TextBlock x:Name="PathLabel" Text="..." Foreground="#94A3B8" FontSize="12" FontWeight="SemiBold"/>
                </StackPanel>
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <Button x:Name="SelectAllButton" Content="Select All" Width="100" Height="45" Margin="0,0,10,0" 
                        Background="#334155" Foreground="White" BorderThickness="0" FontSize="13" FontWeight="Bold" Click="SelectAll_Click">
                    <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style></Button.Resources>
                </Button>
                <Button x:Name="RemoveAllButton" Content="Remove All" Width="100" Height="45" Margin="0,0,10,0" 
                        Background="#64748B" Foreground="White" BorderThickness="0" FontSize="13" FontWeight="Bold" Click="RemoveAll_Click">
                    <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style></Button.Resources>
                </Button>
                <Button x:Name="DeleteAllButton" Content="Delete All" Width="100" Height="45" Margin="0,0,10,0" 
                        Background="#DC3545" Foreground="White" BorderThickness="0" FontSize="13" FontWeight="Bold" Click="DeleteAll_Click">
                    <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style></Button.Resources>
                </Button>
                <Button x:Name="DownloadButton" Content="START SELECTED" Width="150" Height="45" 
                        Background="#3ABEF9" Foreground="#0F172A" BorderThickness="0" FontSize="14" FontWeight="Bold" Click="DownloadButton_Click">
                    <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style></Button.Resources>
                </Button>
            </StackPanel>
        </Grid>
        </Grid>
    </Grid>
</Window>
