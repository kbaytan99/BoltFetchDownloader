<Window x:Class="BoltFetch.AddLinkWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add Links" Height="300" Width="550"
        WindowStartupLocation="CenterOwner"
        Background="#0F172A" Foreground="#E2E8F0"
        WindowStyle="None" AllowsTransparency="True"
        ResizeMode="NoResize">
    
    <Window.Resources>
        <!-- Modern Button Style -->
        <Style x:Key="DialogButton" TargetType="Button">
            <Setter Property="Background" Value="#1E293B"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#334155"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" BorderThickness="{TemplateBinding BorderThickness}" BorderBrush="{TemplateBinding BorderBrush}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter Property="Background" TargetName="border" Value="#334155"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="true">
                                <Setter Property="Background" TargetName="border" Value="#0F172A"/>
                                <Setter Property="RenderTransform" TargetName="border">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.97" ScaleY="0.97" CenterX="0.5" CenterY="0.5"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Border BorderBrush="#3ABEF9" BorderThickness="1" CornerRadius="8" Background="#0F172A">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
                <TextBlock Text="🔗" FontSize="20" Foreground="#3ABEF9" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <TextBlock Text="Add Download Links" FontSize="18" FontWeight="Bold" Foreground="#F8FAFC" VerticalAlignment="Center"/>
            </StackPanel>

            <!-- Input Box -->
            <TextBox x:Name="LinksTextBox" Grid.Row="1" Background="#1E293B" Foreground="White" 
                     BorderBrush="#334155" BorderThickness="1" FontSize="13" TextWrapping="Wrap" 
                     AcceptsReturn="True" VerticalScrollBarVisibility="Auto" Padding="10"
                     CaretBrush="#3ABEF9">
                <TextBox.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="6"/>
                    </Style>
                </TextBox.Resources>
            </TextBox>

            <TextBlock Grid.Row="1" Text="Paste your GoFile links here (one per line)..." 
                       Foreground="#64748B" FontSize="13" Margin="12,12,0,0" IsHitTestVisible="False">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Text, ElementName=LinksTextBox}" Value="">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                        <Setter Property="Visibility" Value="Hidden"/>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

            <!-- Actions -->
            <Grid Grid.Row="2" Margin="0,15,0,0">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                    <Button Content="Paste from Clipboard" Style="{StaticResource DialogButton}" Background="#1E293B" Click="PasteButton_Click"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Cancel" Style="{StaticResource DialogButton}" Margin="0,0,10,0" Click="CancelButton_Click"/>
                    <Button Content="Add Links" Style="{StaticResource DialogButton}" Background="#3ABEF9" Foreground="#0F172A" Click="AddButton_Click"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
