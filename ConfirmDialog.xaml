<Window x:Class="BoltFetch.ConfirmDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Confirm" Height="220" Width="450"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ResizeMode="NoResize" ShowInTaskbar="False" Deactivated="Window_Deactivated">
    <Border Background="#1E293B" CornerRadius="12" BorderBrush="#334155" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="5" Color="Black" Opacity="0.6"/>
        </Border.Effect>
        <Grid Margin="24,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title -->
            <StackPanel Orientation="Horizontal" Grid.Row="0">
                <TextBlock x:Name="IconText" Text="⚠️" FontFamily="Segoe UI Emoji" FontSize="22" VerticalAlignment="Center" Margin="0,0,12,0"/>
                <TextBlock x:Name="TitleText" Text="Confirm" FontSize="18" FontWeight="Bold" Foreground="#F8FAFC" VerticalAlignment="Center"/>
            </StackPanel>

            <!-- Message -->
            <TextBlock x:Name="MessageText" Grid.Row="1" Text="" TextWrapping="Wrap" 
                       Foreground="#94A3B8" FontSize="13" Margin="0,14,0,14" LineHeight="20"/>

            <!-- Buttons -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancel" Width="100" Height="38" Margin="0,0,10,0" Click="Cancel_Click"
                        Background="Transparent" Foreground="#94A3B8" BorderBrush="#475569" BorderThickness="1" FontSize="12" FontWeight="SemiBold" Cursor="Hand">
                    <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="8"/></Style></Button.Resources>
                </Button>
                <Button x:Name="ConfirmBtn" Content="Confirm" Width="100" Height="38" Click="Confirm_Click"
                        Foreground="White" BorderThickness="0" FontSize="12" FontWeight="Bold" Cursor="Hand">
                    <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="8"/></Style></Button.Resources>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</Window>
